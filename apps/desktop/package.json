{
    "name": "@onlook/desktop",
    "version": "0.0.1",
    "description": "Weblab desktop app",
    "author": {
        "name": "Weblab",
        "email": "contact@weblab.build"
    },
    "main": "main.js",
    "private": true,
    "packageManager": "bun@1.3.1",
    "scripts": {
        "start": "electron .",
        "link:node_modules": "node -e \"const fs=require('fs');const path=require('path');const link=path.join(process.cwd(),'node_modules');const target=path.resolve(process.cwd(),'../../node_modules');try{fs.rmSync(link,{recursive:true,force:true});}catch{}fs.symlinkSync(target,link,process.platform==='win32'?'junction':'dir');\"",
        "build:mac": "bun run link:node_modules && electron-builder --mac",
        "build:win": "bun run link:node_modules && electron-builder --win",
        "build:linux": "bun run link:node_modules && electron-builder --linux",
        "build": "bun run link:node_modules && electron-builder --mac --win --linux"
    },
    "dependencies": {
        "electron-updater": "^6.3.9"
    },
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.weblab.desktop",
        "productName": "Weblab",
        "copyright": "Copyright © 2025-2026 Weblab",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "assets/**"
        ],
        "mac": {
            "category": "public.app-category.developer-tools",
            "icon": "assets/icon.icns",
            "target": [
                { "target": "dmg", "arch": ["universal"] }
            ],
            "artifactName": "Weblab.dmg"
        },
        "win": {
            "icon": "assets/icon.ico",
            "target": [
                { "target": "nsis", "arch": ["x64"] }
            ],
            "artifactName": "Weblab-Setup.exe"
        },
        "linux": {
            "icon": "assets/icon.png",
            "target": [
                { "target": "AppImage", "arch": ["x64"] }
            ],
            "category": "Development",
            "artifactName": "Weblab.AppImage"
        },
        "npmRebuild": false,
        "publish": {
            "provider": "github",
            "owner": "weblab",
            "repo": "weblab"
        }
    }
}
