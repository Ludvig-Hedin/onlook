{
    "name": "@onlook/mcp",
    "description": "Weblab MCP server — exposes Weblab's file, bash, and project tools via Model Context Protocol",
    "type": "module",
    "module": "src/server.ts",
    "version": "0.0.1",
    "private": true,
    "bin": {
        "weblab-mcp": "./src/server.ts"
    },
    "scripts": {
        "start": "bun src/server.ts",
        "clean": "rm -rf node_modules",
        "lint": "eslint . --max-warnings 0",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "onlook",
        "weblab",
        "mcp"
    ],
    "author": {
        "name": "Onlook",
        "email": "contact@onlook.com"
    },
    "license": "Apache-2.0",
    "devDependencies": {
        "@onlook/eslint": "*",
        "@onlook/typescript": "*",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "zod": "^4.1.3"
    }
}
